{
  "configVersion": "v3",
  "app": {
    "appId": 24770,
    "appName": "Currency Converter",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Convert currencies on your watch with real-time calculations"
  },
  "permissions": ["device:os.local_storage"],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0.0",
      "target": "3.0.0",
      "minVersion": "3.0"
    }
  },
  "targets": {
    "common": {
      "module": {
        "page": {
          "pages": [
            "page/index",
            "page/amount-select",
            "page/from-currency-select",
            "page/to-currency-select"
          ]
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        },
        {
          "st": "b"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Currency Converter"
    }
  },
  "defaultLanguage": "en-US"
}
